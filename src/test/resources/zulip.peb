{
    "channel": "#random",
    "blocks": [
    {% for block in blocks %}
        {
            "type": "section",
            "text": {
                "type": "mrkdwn",
                "text": {{ block.text | toJson }}
            }
        },
        {
            "type": "section",
            "fields": [
                {% for field in block.fields %}
                {
                    "type": "mrkdwn",
                    "text": {{ field | toJson }}
                }
                {{ loop.last == 'false' ? ',' : '' }}
                {% endfor %}
            ]
        },
        {
        "type": "divider"
        }
        {{ loop.last == 'false' ? ',' : '' }}
    {% endfor %}
    ]
}
